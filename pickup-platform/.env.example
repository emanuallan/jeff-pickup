# Supabase (create a new project — do NOT reuse the PoC project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Domain for subdomain routing (use localhost for local dev with slug.localhost:3000)
NEXT_PUBLIC_ROOT_DOMAIN=organizr.co

# Server-only — required for "Generate sessions" button and Vercel Cron
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron auth (set same value in Vercel dashboard)
CRON_SECRET=generate-a-random-string

# Stripe (sponsorships)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
PLATFORM_FEE_PERCENT=5
SPONSORSHIP_MIN_PRICE_CENTS=500
